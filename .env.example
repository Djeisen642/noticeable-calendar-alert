# Google OAuth credentials for the real GoogleCalendarSync.
#
# Copy to `.env` and fill in. WITHOUT these, the app falls back to the
# deterministic MockCalendarSync (so `npm run dev` keeps working credential-free).
#
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
#   1. Enable the "Google Calendar API".
#   2. Create credentials -> OAuth client ID -> Application type: "Desktop app".
#   3. Add the scope: https://www.googleapis.com/auth/calendar.events.readonly
#   4. Paste the client ID + secret below.
#
# For a Desktop-app client these are NOT treated as confidential by Google;
# PKCE provides the real protection. Even so, `.env` is gitignored.

VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=your-client-secret

# Loopback redirect port (must be free). Defaults to 1421 if unset.
VITE_OAUTH_REDIRECT_PORT=1421
