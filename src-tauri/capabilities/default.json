{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Least-privilege permissions for the overlay window: only the commands the JS bridge actually invokes. Window positioning, cursor-event toggling and monitor queries are performed Rust-side in lib.rs and do not pass through the capability system.",
  "windows": ["overlay"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:event:allow-listen",
    "dialog:allow-message",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://*" }]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://oauth2.googleapis.com/token" },
        { "url": "https://www.googleapis.com/calendar/v3/*" }
      ]
    }
  ]
}
