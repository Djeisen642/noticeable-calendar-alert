{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits", "group:monorepos"],
  "timezone": "America/New_York",
  "schedule": ["* 0-6 1 * *"],
  "labels": ["dependencies"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 5,
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Batch all non-major npm updates into a single monthly PR.",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "groupName": "npm non-major",
      "groupSlug": "npm-non-major"
    },
    {
      "description": "Batch all Cargo (Tauri/Rust) non-major updates together.",
      "matchManagers": ["cargo"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "cargo non-major",
      "groupSlug": "cargo-non-major"
    },
    {
      "description": "Batch GitHub Actions updates together.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Major updates get their own PR for careful review.",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 0-6 1 * *"]
  }
}
